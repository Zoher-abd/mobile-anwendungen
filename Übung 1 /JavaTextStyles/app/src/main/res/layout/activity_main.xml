<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="1. Standardtext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:text="2. Roter Text"
        android:textColor="#FF0000"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:text="3. Blauer Text"
        android:textColor="#0000FF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:text="4. Fett &amp; Kursiv"
        android:textStyle="bold|italic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:text="5. Großer Text"
        android:textSize="24sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:text="5. Kleiner Text"
        android:textSize="12sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/customFontText"
        android:text="6. Eigene Schriftart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:text="7. https://www.google.com"
        android:autoLink="web"
        android:textColorLink="#0000FF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</LinearLayout>
